# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Scraper
SCRAPER_API_KEY=your_shared_api_key
PORT=4000

# OpenAI (job title classification: US-based remote software engineer roles)
# If OPENAI_API_KEY is empty, classification is skipped and the scraper keeps
# only the title-keyword behavior.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Daily auto-scrape (defaults to 1:00 PM America/Chicago, DST-aware).
# Requires the scraper process to be running at that time. Set
# SCRAPE_CRON_ENABLED=false to turn the schedule off.
SCRAPE_CRON_ENABLED=true
SCRAPE_CRON_EXPR=0 13 * * *
SCRAPE_CRON_TZ=America/Chicago
